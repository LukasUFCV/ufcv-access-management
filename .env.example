CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
MOCK_CONNECTORS_ENABLED=true
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GRAPH_BASE_URL=https://graph.microsoft.com
DIRECTORY_SYNC_STRATEGY=mock
